SkinMDLGeometryUsingShelfButtons.visibility\" 1;\nsetAttr \"annotation7_FinalizeWithShelfButton.visibility\" 1;\nsetAttr \"*:redundant_GRP.visibility\" 0;\n\n\n// Check if createKrogerShelf shelf is present  and deletes it//\n\nif (`objExists createKrogerShelf`) {\n    // Delete createKrogerShelf //\n    select -r createKrogerShelf;\n    doDelete;\n    \n}\n\nselect -cl  ;\n\nprint(\"Done Creating Blendshapes, Skin Clusters and Wire Deformers on Rig Template. Now Skin MDL geo to joints\");" 
