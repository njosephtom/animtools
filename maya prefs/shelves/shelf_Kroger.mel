;\nsetAttr FKLidOutOutline_LShape.overrideColor 6;\nsetAttr FKLidOut_LShape.overrideColor 6;\nsetAttr FKLidBottomOut_LShape.overrideColor 6;\nsetAttr FKLidBottomMiddle_LShape.overrideColor 6;\nsetAttr FKLidBottomIn_LShape.overrideColor 6;\nsetAttr FKLidMove_LShape.overrideColor 22;\nsetAttr FKLipCornerPullOut_LShape.overrideColor 6;\nsetAttr FKLipTopSidePullOut_LShape.overrideColor 6;\nsetAttr FKLipBottomSidePullOut_LShape.overrideColor 6;\nsetAttr FKLipCorner_LShape.overrideColor 6;\nsetAttr FKLipCornerOutline_LShape.overrideColor 6;\nsetAttr FKLipTopSide_LShape.overrideColor 6;\nsetAttr FKLipBottomSideOutline_LShape.overrideColor 6;\nsetAttr FKLipBottomSide_LShape.overrideColor 6;\nsetAttr FKMiddleFinger3_LShape.overrideColor 6;\nsetAttr FKMiddleFinger2_LShape.overrideColor 6;\nsetAttr FKThumbFinger3_LShape.overrideColor 6;\nsetAttr FKMiddleFinger1_LShape.overrideColor 6;\nsetAttr FKThumbFinger2_LShape.overrideColor 6;\nsetAttr FKThumbFinger1_LShape.overrideColor 6;\nsetAttr FKIndexFinger3_LShape.overrideColor 6;\nsetAttr FKIndexFinger2_LShape.overrideColor 6;\nsetAttr FKIndexFinger1_LShape.overrideColor 6;\nsetAttr FKPinkyFinger3_LShape.overrideColor 6;\nsetAttr FKPinkyFinger2_LShape.overrideColor 6;\nsetAttr FKPinkyFinger1_LShape.overrideColor 6;\nsetAttr FKRingFinger3_LShape.overrideColor 6;\nsetAttr FKRingFinger2_LShape.overrideColor 6;\nsetAttr FKRingFinger1_LShape.overrideColor 6;\nsetAttr FKCup_LShape.overrideColor 6;\nsetAttr FKWrist_LShape.overrideColor 6;\nsetAttr FKElbow_LShape.overrideColor 6;\nsetAttr FKShoulder_LShape.overrideColor 6;\nsetAttr FKArmPin_LShape.overrideColor 6;\nsetAttr FKScapula_LShape.overrideColor 22;\nsetAttr AimEye_MShape.overrideColor 17;\nsetAttr AimEye_RShape.overrideColor 13;\nsetAttr AimEye_LShape.overrideColor 6;\nsetAttr PoleLeg_RShape.overrideColor 13;\nsetAttr IKLeg_RShape.overrideColor 13;\nsetAttr IKArm_RShape.overrideColor 13;\nsetAttr PoleArm_RShape.overrideColor 13;\n//setAttr IKcvSpine1_MShape.overrideColor 17;\n//setAttr IKcvSpine2_MShape.overrideColor 17;\n//setAttr IKcvSpine3_MShape.overrideColor 17;\n//setAttr IKcvSpine4_MShape.overrideColor 17;\n//setAttr IKcvSpine5_MShape.overrideColor 17;\n//setAttr IKSpine1_MShape.overrideColor 13;\n//setAttr IKSpine2_MShape.overrideColor 13;\nsetAttr IKhybridSpine1_MShape.overrideColor 14;\nsetAttr IKSpine3_MShape.overrideColor 13;\nsetAttr IKhybridSpine2_MShape.overrideColor 14;\nsetAttr IKhybridSpine3_MShape.overrideColor 14;\nsetAttr IKLeg_LShape.overrideColor 6;\nsetAttr PoleLeg_LShape.overrideColor 6;\nsetAttr IKArm_LShape.overrideColor 6;\nsetAttr PoleArm_LShape.overrideColor 6;\nsetAttr FKIKLeg_RShape.overrideColor 13;\nsetAttr FKIKArm_RShape.overrideColor 13;\nsetAttr FKIKSpine_MShape.overrideColor 6;\nsetAttr FKIKLeg_LShape.overrideColor 6;\nsetAttr FKIKArm_LShape.overrideColor 6;\nsetAttr RollToes_RShape.overrideColor 13;\nsetAttr RollToesEnd_RShape.overrideColor 13;\nsetAttr RollHeel_RShape.overrideColor 13;\nsetAttr IKToes_RShape.overrideColor 13;\nsetAttr RollToesEnd_LShape.overrideColor 6;\nsetAttr RollToes_LShape.overrideColor 6;\nsetAttr RollHeel_LShape.overrideColor 6;\nsetAttr IKToes_LShape.overrideColor 6;\nsetAttr HipSwinger_MShape.overrideColor 22;\nsetAttr BendKnee1_RShape.overrideColor 13;\nsetAttr BendKnee2_RShape.overrideColor 13;\nsetAttr BendHip1_RShape.overrideColor 13;\nsetAttr BendHip2_RShape.overrideColor 13;\nsetAttr BendElbow1_RShape.overrideColor 13;\nsetAttr BendElbow2_RShape.overrideColor 13;\nsetAttr BendShoulder1_RShape.overrideColor 13;\nsetAttr BendShoulder2_RShape.overrideColor 13;\nsetAttr BendKnee1_LShape.overrideColor 6;\nsetAttr BendKnee2_LShape.overrideColor 6;\nsetAttr BendHip1_LShape.overrideColor 6;\nsetAttr BendHip2_LShape.overrideColor 6;\nsetAttr BendElbow1_LShape.overrideColor 6;\nsetAttr BendElbow2_LShape.overrideColor 6;\nsetAttr BendShoulder1_LShape.overrideColor 6;\nsetAttr BendShoulder2_LShape.overrideColor 6;\nsetAttr Fingers_LShape.overrideColor 22;\nsetAttr Fingers_RShape.overrideColor 22;\nsetAttr R_AutoBlink_RShape.overrideColor 17;\nsetAttr L_AutoBlink_RShape.overrideColor 17;\nsetAttr closeMouth_MShape.overrideColor 17;\n\n// Finalize, turn visibilities off and create final sets //\n\nsetAttr \"FKEye_L.visibility\" 0;\nsetAttr \"FKEye_R.visibility\" 0;\nsetAttr \"Curves_GRP.visibility\" 0;\nsetAttr \"CopySkinWeights.visibility\" 0;\nselect -r Face_M ;\nselect -add AttributeHolder ;\ndoCreateScaleConstraintArgList 1 { \"1\",\"1\",\"1\",\"1\",\"0\",\"0\",\"0\",\"1\",\"\",\"1\" };\nscaleConstraint -mo -weight 1;\nsetAttr \"New_GRP.visibility\" 1;\nsetAttr \"Old_GRP.visibility\" 1;\nsetAttr \"mouthColor_geo.visibility\" 1;\nsetAttr \"eyeWhite_geo.visibility\" 1;\nsetAttr \"BLS_Arms.Skinny\" 1;\nsetAttr \"FKHead_M.oldNeck\" 1;\nsetAttr \"MotionSystem.visibility\" 1;\nsetAttr \"Geo_grp.visibility\" 1;\nsetAttr \"Main.bendVis\" 0;\n\nselect -r CopySkinWeights OldRigControl_Curves;\n$createSetResult = `sets -name \"delete_SET\"`;\n\nselect -r Geometry ;\n$createSetResult = `sets -name \"bakeSet\"`;\n\n// Create geo sets for shader assignement //\n\nselect -r old_head_geo old_nose_geo old_ears_geo head_geo old_neck_geo Arms_geo R_ChewCheek_geo L_ChewCheek_geo tongue_geo;\n$createSetResult = `sets -name \"SkinColorSet\"`;\n\nselect -r old_r_eye_geo old_l_eye_geo l_eye_geo r_eye_geo eyebrow_geo ;\n$createSetResult = `sets -name \"EyeBrowsColorSet\"`;\n\nselect -r eyeWhite_geo mouthColor_geo teethTop_geo teethBtm_geo;\n$createSetResult = `sets -name \"WhiteColorSet\"`;\n\nselect -r r_eye_outline_geo l_eye_outline_geo mouth_outline_geo ;\n$createSetResult = `sets -name \"OutlinesColorSet\"`;\n\nsets -edit -fe  delete_SET EyeBrowsColorSet ;\nsets -edit -fe  delete_SET SkinColorSet ;\nsets -edit -fe  delete_SET WhiteColorSet ;\nsets -edit -fe  delete_SET OutlinesColorSet ;\n\nparent Geo_grp Geometry ;\nparent SetupAssist MotionSystem ;\nselect -r \"*:*edundant_GRP\" ;\nselect -add \"*:MDL_GRP\" ;\n$sl = `ls -sl`;\n\nparent -a $sl Geometry;\nselect -r Main ;\nsetAttr \"Main.jointVis\" 0;\nselect -r -ne Blendshapes ;\nselect -add -ne DeltaMushDeformers ;\nselect -add -ne EditDrivingSystem ;\nselect -add -ne SkinClusters ;\nselect -add -ne WireDeformers ;\nselect -add -ne WireDeltaMush_ComponentEditing allWireDeformers_Verts_Zeroed DeltaMush_Verts_Zeroed EyesWires_Verts_Zeroed MouthWire_Verts_Zeroed FittedGeo;\ndoDelete;\n\n// Turn off OverrideEnabled on objects under Geometry Group//\n\nstring $geometryGroup = \"Geometry\";\n\nproc setOverrideEnabledToZero(string $object) {\n    setAttr ($object + \".overrideEnabled\") 0;\n    \n    // Check if the object has children\n    if (`nodeType $object` == \"transform\") {\n        string $children[] = `listRelatives -fullPath -children $object`;\n        for ($child in $children) {\n            setOverrideEnabledToZero($child);\n        }\n    }\n}\n\n// Check if the Geometry group exists\nif (objExists($geometryGroup) && `nodeType $geometryGroup` == \"transform\") {\n    setOverrideEnabledToZero($geometryGroup);\n    \n}\n\nsetAttr \"Geometry.overrideEnabled\" 1;\nsetAttr \"Geometry.overrideDisplayType\" 2;\nsetAttr \"Geo_grp.overrideShading\" 1;\n\nselect -r Annotations ;\ndoDelete;\n\n// Add Geo Selectable Attribute//\naddAttr -ln \"geoSelect\"  -at \"enum\" -en \"Normal:Reference:\"  Main;\nsetAttr -e-keyable true Main.geoSelect;\nconnectAttr -f Main.geoSelect AttributeHolder.geoSelect;\nconnectAttr -f AttributeHolder.geoSelect Geometry.overrideEnabled;\nsetAttr \"Main.geoSelect\" 1;\nsetAttr -keyable false -channelBox true \"Main.geoSelect\";\n\n\n\n// Check if createKrogerShelf shelf is present  and deletes it//\n\nif (`objExists createKrogerShelf`) {\n    // Delete createKrogerShelf //\n    select -r createKrogerShelf;\n    doDelete;\n    \n}\n\n\nselect -r AttributeHolder ;\n\nprint(\"Rigging is done. Now test\");\n" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
        -mi "----------------------------------------------" ( "print(\"User defined menuItem\");" )
        -mi "Reset Neck weights to Head and Neck One Piece" ( "setAttr \"FKHead_M.oldNeck\" 0;\nselect -r HeadWeights ;\nselect -add head_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -cl  ;" )
        -mi "Reset Neck weights to Head and Neck Separate" ( "setAttr \"FKHead_M.oldNeck\" 1;\nskinPercent -tv Face_M 1 SkinHead head_geo.vtx[1744:1963] head_geo.vtx[3620:3817];\nselect -cl  ;" )
    ;

} 
