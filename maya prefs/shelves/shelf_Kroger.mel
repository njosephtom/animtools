        -command "// Delete all display layers in the scene //\nstring $displayLayers[] = `ls -type \"displayLayer\"`;\n\nfor ($layer in $displayLayers) {\n    if ($layer != \"defaultLayer\") {\n        delete $layer;\n    }\n}\n\n// Select Face controls and add Pullout Attributes //\n\nselect -r FKLidOut_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidOut_R.pullOut ;\nselect -r FKLidTopOut_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidTopOut_R.pullOut ;\nselect -r FKLidTopMiddle_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidTopMiddle_R.pullOut ;\nselect -r FKLidTopIn_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidTopIn_R.pullOut ;\nselect -r FKLidIn_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidIn_R.pullOut ;\nselect -r FKLidBottomIn_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidBottomIn_R.pullOut ;\nselect -r FKLidBottomMiddle_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidBottomMiddle_R.pullOut ;\nselect -r FKLidBottomOut_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidBottomOut_R.pullOut ;\nselect -r FKCheekBone_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKCheekBone_R.pullOut ;\nselect -r FKCheek_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKCheek_R.pullOut ;\nselect -r FKSmilePull_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKSmilePull_R.pullOut ;\nselect -r FKCheekRaiser_R ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKCheekRaiser_R.pullOut ;\nselect -r FKLidTopIn_L ;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidTopIn_L.pullOut ;\nselect -r FKLidIn_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidIn_L.pullOut ;\nselect -r FKLidBottomIn_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidBottomIn_L.pullOut ;\nselect -r FKLidBottomMiddle_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidBottomMiddle_L.pullOut ;\nselect -r FKLidBottomOut_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidBottomOut_L.pullOut ;\nselect -r FKLidOut_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidOut_L.pullOut ;\nselect -r FKLidTopOut_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidTopOut_L.pullOut ;\nselect -r FKLidTopMiddle_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLidTopMiddle_L.pullOut ;\nselect -r FKCheek_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKCheek_L.pullOut ;\nselect -r FKCheekBone_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKCheekBone_L.pullOut ;\nselect -r FKSmilePull_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKSmilePull_L.pullOut ;\nselect -r FKCheekRaiser_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKCheekRaiser_L.pullOut ;\nselect -r FKLipBottomSide_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipBottomSide_L.pullOut ;\nselect -r FKLipBottomMiddle_M;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipBottomMiddle_M.pullOut ;\nselect -r FKLipBottomSide_R;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipBottomSide_R.pullOut ;\nselect -r FKLipCorner_R;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipCorner_R.pullOut ;\nselect -r FKLipCorner_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipCorner_L.pullOut ;\nselect -r FKLipTopSide_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipTopSide_L.pullOut ;\nselect -r FKLipTopMiddle_M;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipTopMiddle_M.pullOut ;\nselect -r FKLipTopSide_R;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKLipTopSide_R.pullOut ;\nselect -r FKChew_R;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKChew_R.pullOut ;\nselect -r FKChew_L;\naddAttr -ln \"pullOut\" -at double  -min -2 -max 3 -dv 0 ;\nsetAttr -keyable true FKChew_L.pullOut ;\n\n// Connect Pullout attributes to Pullout Controls //\n\nconnectAttr -f FKLidTopOut_R.pullOut FKLidTopOutPullout_R.translateX;\nconnectAttr -f FKLidTopMiddle_R.pullOut FKLidTopMiddlePullout_R.translateX;\nconnectAttr -f FKLidTopIn_R.pullOut FKLidTopInPullout_R.translateX;\nconnectAttr -f FKLidIn_R.pullOut FKLidInPullout_R.translateX;\nconnectAttr -f FKLidBottomIn_R.pullOut FKLidBottomInPullout_R.translateX;\nconnectAttr -f FKLidBottomMiddle_R.pullOut FKLidBottomMiddlePullout_R.translateX;\nconnectAttr -f FKLidBottomOut_R.pullOut FKLidBottomOutPullout_R.translateX;\nconnectAttr -f FKLidOut_R.pullOut FKLidOutPullout_R.translateX;\nconnectAttr -f FKLidTopIn_L.pullOut FKLidTopInPullout_L.translateX;\nconnectAttr -f FKLidTopMiddle_L.pullOut FKLidTopMiddlePullout_L.translateX;\nconnectAttr -f FKLidTopOut_L.pullOut FKLidTopOutPullout_L.translateX;\nconnectAttr -f FKLidOut_L.pullOut FKLidOutPullout_L.translateX;\nconnectAttr -f FKLidBottomOut_L.pullOut FKLidBottomOutPullout_L.translateX;\nconnectAttr -f FKLidBottomMiddle_L.pullOut FKLidBottomMiddlePullout_L.translateX;\nconnectAttr -f FKLidBottomIn_L.pullOut FKLidBottomInPullout_L.t