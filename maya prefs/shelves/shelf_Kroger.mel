global proc shelf_Kroger () {
    global string $gBuffStr;
    global string $gBuffStr0;
    global string $gBuffStr1;


    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 2
        -flexibleWidthValue 100
        -enable 1
        -width 100
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Delete Fitting" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "// Delete history in meshes\nselect -r ArmsWeights HeadWeights Le..." 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Delete Fitting" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 1 
        -image "R:/SANDBOX/carlosS/yellow_100.png" 
        -image1 "R:/SANDBOX/carlosS/yellow_100.png" 
        -style "iconOnly" 
        -marginWidth 1
        -marginHeight 1
        -command "// Delete history in meshes\nselect -r ArmsWeights HeadWeights LegWeights TorsoWeights old_head_BLS head_BLS bigSquint btmLidSquint sideLidSquint r_bigSquint r_btmLidSquint r_sideLidSquint l_bigSquint l_btmLidSquint l_sideLidSquint oldEars oldMouth oldNeck oldNose oldEyes closeMouth BlinkR BlinkL newMouth flatMouth flatEyes thickNeck Skinny Divet_R Divet_L old_head_geo old_neck_geo old_nose_geo old_ears_geo old_r_eye_geo old_l_eye_geo head_geo l_eye_geo r_eye_geo tongue_geo teethTop_geo teethBtm_geo mouthColor_geo eyeWhite_geo r_eye_outline_geo l_eye_outline_geo mouth_outline_geo R_ChewCheek_geo L_ChewCheek_geo Arms_geo l_brow_crv r_brow_crv mouth_back_crv mouth_crv mouth_OutlineCrv r_eye_back_crv r_eye_crv r_eye_OutlineCrv l_eye_back_crv l_eye_crv l_eye_OutlineCrv autoBlink_R_CTRL_blendhape autoBlink_L_CTRL_blendshape closeMouth_CTRL_blendshape rightLegStart_CTRL_blendshape leftLegStart_CTRL_blendshape lowerTeeth_CTRL_blendshape tongue_CTRL_blendshape upperTeeth_CTRL_blendshape FKCup_R_blendshape FKThumbFinger1_R_blendshape FKCup_L_blendshape FKThumbFinger1_L_blendshape;\nDeleteHistory;\n\n// Clear the current selection\nselect -cl;\n\nsetAttr \"annotation2_DeleteFittingControlsUsingShelfButton.visibility\" 0;\nsetAttr \"annotation1_UseControlsToFitToMDLGeo.visibility\" 0;\nsetAttr \"annotation3_AddJointsIfNecessary.visibility\" 1;\nsetAttr \"annotation4_BuildAdvancedSkeleton.visibility\" 1;\nsetAttr \"annotation5_ConnectDeformersWithShelfButton.visibility\" 1;\n\n\n// Select and Delete Fitting Tools plus all constraints in the scene\nselect -r HandRight_FitJoint_parentConstraint1 HandRight_FitJoint_scaleConstraint1 ScapulaRight_FitJoint_parentConstraint1 ScapulaRight_FitJoint_scaleConstraint1 ShoulderRight_FitJoint_parentConstraint1 ShoulderRight_FitJoint_scaleConstraint1 ElbowRight_FitJoint_parentConstraint1 ElbowRight_FitJoint_scaleConstraint1 HandLeft_FitJoint_parentConstraint1 HandLeft_FitJoint_scaleConstraint1 ScapulaLeft_FitJoint_parentConstraint1 ScapulaLeft_FitJoint_scaleConstraint1 ShoulderLeft_FitJoint_parentConstraint1 ShoulderLeft_FitJoint_scaleConstraint1 ElbowLeft_FitJoint_parentConstraint1 ElbowLeft_FitJoint_scaleConstraint1 Chest_FitJoint_parentConstraint1 Chest_FitJoint_scaleConstraint1 Spine_FitJoint_parentConstraint1 Spine_FitJoint_scaleConstraint1 Pelvis_FitJoint_parentConstraint1 Pelvis_FitJoint_scaleConstraint1 NeckBottom_FitJoint_parentConstraint1 NeckBottom_FitJoint_grp_parentConstraint1 NeckBottom_FitJoint_grp_scaleConstraint1 LegTop_Right_FitJoint_parentConstraint1 LegTop_Right_FitJoint_scaleConstraint1 Knee_Right_FitJoint_parentConstraint1 Knee_Right_FitJoint_scaleConstraint1 Foot_Right_FitJoint_parentConstraint1 Foot_Right_FitJoint_scaleConstraint1 Heel_Right_FitJoint_parentConstraint1 Heel_Right_FitJoint_scaleConstraint1 Ball_Right_FitJoint_parentConstraint1 Ball_Right_FitJoint_scaleConstraint1 ToesEnd_Right_FitJoint_parentConstraint1 ToesEnd_Right_FitJoint_scaleConstraint1 LegPin_Right_FitJoint_parentConstraint1 LegPin_Right_FitJoint_scaleConstraint1 FootBottm_Right_FitJoint_parentConstraint1 FootBottm_Right_FitJoint_scaleConstraint1 FootBottm_Left_FitJoint_parentConstraint1 FootBottm_Left_FitJoint_scaleConstraint1 FootOuter_Right_FitJoint_parentConstraint1 group1_parentConstraint1 group1_scaleConstraint1 Head_FitJoint_parentConstraint1 Head_FitJoint_scaleConstraint1 NeckThicknessFit_FitJoint_parentConstraint1 NeckThicknessFit_FitJoint_scaleConstraint1 NeckFit_FitJoint_parentConstraint1 NeckFit_FitJoint_scaleConstraint1 LegTop_Left_FitJoint_parentConstraint1 LegTop_Left_FitJoint_scaleConstraint1 Knee_Left_FitJoint_parentConstraint1 Knee_Left_FitJoint_scaleConstraint1 Foot_Left_FitJoint_parentConstraint1 Foot_Left_FitJoint_scaleConstraint1 Heel_Left_FitJoint_parentConstraint1 Heel_Left_FitJoint_scaleConstraint1 Ball_Left_FitJoint_parentConstraint1 Ball_Left_FitJoint_scaleConstraint1 FootInner_Left_FitJoint_parentConstraint1 FootInner_Left_FitJoint_scaleConstraint1 ToesEnd_Left_FitJoint_parentConstraint1 ToesEnd_Left_FitJoint_scaleConstraint1 FootOuter_Left_FitJoint_parentConstraint1 FootOuter_Left_FitJoint_scaleConstraint1 LegPin_Left_FitJoint_parentConstraint1 LegPin_Left_FitJoint_scaleConstraint1 NeckThickness_FitControl_grp_parentConstraint1 NeckThickness_FitControl_grp_scaleConstraint1 Elbow_FitControl_grp_parentConstraint1 Elbow_FitControl_grp_scaleConstraint1 Shoulder_FitControl_grp_parentConstraint1 Shoulder_FitControl_grp_scaleConstraint1 Scapula_FitControl_grp_scaleConstraint1 Scapula_FitControl_grp_parentConstraint1 Elbow_L_FitControl_grp_scaleConstraint1 Elbow_L_FitControl_grp_parentConstraint1 Shoulder_L_FitControl_grp_scaleConstraint1 Shoulder_L_FitControl_grp_parentConstraint1 Scapula_L_FitControl_grp_parentConstraint1 Scapula_L_FitControl_grp_scaleConstraint1 Knee_Right_FitControl_grp_scaleConstraint1 Knee_Right_FitControl_grp_parentConstraint1 FootBottom_Right_FitControl_grp_scaleConstraint1 FootBottom_Right_FitControl_grp_parentConstraint1 ToesEnd_Right_FitControl_grp_parentConstraint1 ToesEnd_Right_FitControl_grp_scaleConstraint1 Ball_Right_FitControl_grp_parentConstraint1 Ball_Right_FitControl_grp_scaleConstraint1 Heel_Right_FitControl_grp_parentConstraint1 Heel_Right_FitControl_grp_scaleConstraint1 LegTop_Right_FitControl_grp_parentConstraint1 LegTop_Right_FitControl_grp_scaleConstraint1 LegPIn_Right_FitControl_grp_parentConstraint1 LegPIn_Right_FitControl_grp_scaleConstraint1 LegTopPin_Right_FitControl_grp_parentConstraint1 Spine_FitControl_grp_parentConstraint1 Chest_FitControl_grp_parentConstraint1 Knee_Left_FitControl_grp_scaleConstraint2 Knee_Left_FitControl_grp_parentConstraint2 FootBottom_Left_FitControl_grp_scaleConstraint2 FootBottom_Left_FitControl_grp_parentConstraint2 ToesEnd_Left_FitControl_grp_scaleConstraint2 ToesEnd_Left_FitControl_grp_parentConstraint2 Ball_Left_FitControl_grp_parentConstraint1 Ball_Left_FitControl_grp_scaleConstraint1 Heel_Left_FitControl_grp_scaleConstraint2 Heel_Left_FitControl_grp_parentConstraint2 LegTop_Left_FitControl_grp_scaleConstraint2 LegTop_Left_FitControl_grp_parentConstraint2 LegPIn_Left_FitControl_grp_scaleConstraint2 LegPIn_Left_FitControl_grp_parentConstraint2 LegTopPin_Left_FitControl_grp_parentConstraint1 Neck_FitControl_grp_scaleConstraint1 Neck_FitControl_grp_parentConstraint1 Neck_FitControl_OFST_grp_parentConstraint1 ;\ndoDelete;\nselect -r HeadEnd_parentConstraint1 HeadEnd_scaleConstraint1 EarTipEnd_parentConstraint1 EarTipEnd_scaleConstraint1 EarTip_parentConstraint1 EarTip_scaleConstraint1 EarBase_parentConstraint1 EarBase_scaleConstraint1 TeethLowerEnd_parentConstraint1 TeethLowerEnd_scaleConstraint1 TeethLower_parentConstraint1 TeethLower_scaleConstraint1 TongueEnd_parentConstraint1 TongueEnd_scaleConstraint1 Tongue_parentConstraint1 Tongue_scaleConstraint1 TeethUpperEnd_parentConstraint1 TeethUpper_parentConstraint1 TeethUpperEnd_scaleConstraint1 TeethUpper_scaleConstraint1 BrowOrient_parentConstraint1 BrowOrient_scaleConstraint1 Brow7_parentConstraint1 Brow7_scaleConstraint1 Brow1_parentConstraint1 Brow1_scaleConstraint1 Brow6_parentConstraint1 Brow6_scaleConstraint1 Brow2_parentConstraint1 Brow2_scaleConstraint1 Brow5_parentConstraint1 Brow5_scaleConstraint1 Brow3_parentConstraint1 Brow3_scaleConstraint1 Brow8_parentConstraint1 Brow8_scaleConstraint1 Brow4_parentConstraint1 Brow4_scaleConstraint1 BrowMoveBase_parentConstraint1 BrowMoveBase_scaleConstraint1 BrowEnd_parentConstraint1 BrowEnd_scaleConstraint1 Brow_parentConstraint1 Brow_scaleConstraint1 BrowBase_parentConstraint1 BrowBase_scaleConstraint1 NoseOrient_parentConstraint1 NoseOrient_scaleConstraint1 NoseSide_parentConstraint1 NoseSide_scaleConstraint1 NoseTop_parentConstraint1 NoseTop_scaleConstraint1 NoseBottom_parentConstraint1 NoseBottom_scaleConstraint1 NoseMoveBase_parentConstraint1 NoseMoveBase_scaleConstraint1 Nose_parentConstraint1 Nose_scaleConstraint1 NoseBase_parentConstraint1 NoseBase_scaleConstraint1 SmilePullOut_parentConstraint1 SmilePullOut_scaleConstraint1 SmilePullMoveBase_parentConstraint1 SmilePullMoveBase_scaleConstraint1 SmilePull_parentConstraint1 SmilePull_scaleConstraint1 SmilePullBase_parentConstraint1 SmilePullBase_scaleConstraint1 CheekBonePullOut_parentConstraint1 CheekBonePullOut_scaleConstraint1 CheekBoneMoveBase_parentConstraint1 CheekBoneMoveBase_scaleConstraint1 CheekBone_parentConstraint1 CheekBoneBase_parentConstraint1 CheekBoneBase_scaleConstraint1 CheekBone_scaleConstraint1 CheekPullOut_parentConstraint1 CheekPullOut_scaleConstraint1 CheekMoveBase_parentConstraint1 CheekMoveBase_scaleConstraint1 Cheek_parentConstraint1 Cheek_scaleConstraint1 CheekBase_parentConstraint1 CheekBase_scaleConstraint1 CheekRaiserPullOut_parentConstraint1 CheekRaiserPullOut_scaleConstraint1 CheekRaiserMoveBase_parentConstraint1 CheekRaiserMoveBase_scaleConstraint1 CheekRaiser_parentConstraint1 CheekRaiser_scaleConstraint1 CheekRaiserBase_parentConstraint1 CheekRaiserBase_scaleConstraint1 ChewPullOut_parentConstraint1 ChewPullOut_scaleConstraint1 ChewMoveBase_parentConstraint1 ChewMoveBase_scaleConstraint1 Chew_parentConstraint1 Chew_scaleConstraint1 ChewBase_parentConstraint1 ChewBase_scaleConstraint1 EyeOrient_parentConstraint1 EyeOrient_scaleConstraint1 Eye_parentConstraint1 Eye_scaleConstraint1 LidInPullout_parentConstraint1 LidInPullout_scaleConstraint1 LidInBase_parentConstraint1 LidInBase_scaleConstraint1 LidTopInPullout_parentConstraint1 LidTopInPullout_scaleConstraint1 LidTopInBase_parentConstraint1 LidTopInBase_scaleConstraint1 LidTopMiddlePullout_parentConstraint1 LidTopMiddlePullout_scaleConstraint1 LidTopMiddleBase_parentConstraint1 LidTopMiddleBase_scaleConstraint1 LidTopOutPullout_parentConstraint1 LidTopOutBase_parentConstraint1 LidTopOutPullout_scaleConstraint1 LidTopOutBase_scaleConstraint1 LidOutPullout_parentConstraint1 LidOutPullout_scaleConstraint1 LidOutBase_parentConstraint1 LidOutBase_scaleConstraint1 LidBottomOutPullout_parentConstraint1 LidBottomOutPullout_scaleConstraint1 LidBottomOutBase_parentConstraint1 LidBottomOutBase_scaleConstraint1 LidBottomMiddlePullout_parentConstraint1 LidBottomMiddlePullout_scaleConstraint1 LidBottomMiddleBase_parentConstraint1 LidBottomMiddleBase_scaleConstraint1 LidBottomInPullout_parentConstraint1 LidBottomInPullout_scaleConstraint1 LidBottomInBase_parentConstraint1 LidBottomInBase_scaleConstraint1 LidMoveEnd_parentConstraint1 LidMoveEnd_scaleConstraint1 LidInEnd_parentConstraint1 LidInEnd_scaleConstraint1 LidInOutline_parentConstraint1 LidInOutline_scaleConstraint1 LidIn_parentConstraint1 LidIn_scaleConstraint1 LidInOrigin_parentConstraint1 LidInOrigin_scaleConstraint1 LidTopInEnd_parentConstraint1 LidTopInEnd_scaleConstraint1 LidTopInOutline_parentConstraint1 LidTopInOutline_scaleConstraint1 LidTopIn_parentConstraint1 LidTopIn_scaleConstraint1 LidTopInOrigin_parentConstraint1 LidTopInOrigin_scaleConstraint1 LidTopMiddleEnd_parentConstraint1 LidTopMiddleEnd_scaleConstraint1 LidTopMiddleOutline_parentConstraint1 LidTopMiddleOutline_scaleConstraint1 LidTopMiddle_parentConstraint1 LidTopMiddle_scaleConstraint1 LidTopMiddleOrigin_parentConstraint1 LidTopMiddleOrigin_scaleConstraint1 LidTopOutEnd_parentConstraint1 LidTopOutEnd_scaleConstraint1 LidTopOutOutline_parentConstraint1 LidTopOutOutline_scaleConstraint1 LidTopOut_parentConstraint1 LidTopOut_scaleConstraint1 LidTopOutOrigin_parentConstraint1 LidTopOutOrigin_scaleConstraint1 LidOutEnd_parentConstraint1 LidOutEnd_scaleConstraint1 LidOutOutline_parentConstraint1 LidOutOutline_scaleConstraint1 LidOut_parentConstraint1 LidOut_scaleConstraint1 LidOutOrigin_parentConstraint1 LidOutOrigin_scaleConstraint1 LidBottomOutEnd_parentConstraint1 LidBottomOutEnd_scaleConstraint1 LidBottomOut_parentConstraint1 LidBottomOut_scaleConstraint1 LidBottomOutOrigin_parentConstraint1 LidBottomOutOrigin_scaleConstraint1 LidBottomMiddleEnd_parentConstraint1 LidBottomMiddleEnd_scaleConstraint1 LidBottomMiddle_parentConstraint1 LidBottomMiddle_scaleConstraint1 LidBottomMiddleOrigin_parentConstraint1 LidBottomMiddleOrigin_scaleConstraint1 LidBottomInEnd_parentConstraint1 LidBottomInEnd_scaleConstraint1 LidBottomIn_parentConstraint1 LidBottomIn_scaleConstraint1 LidBottomInOrigin_parentConstraint1 LidBottomInOrigin_scaleConstraint1 LidMove_parentConstraint1 LidMove_scaleConstraint1 LidBase_parentConstraint1 LidBase_scaleConstraint1 LipCornerPullOut_parentConstraint1 LipCornerPullOut_scaleConstraint1 LipCornerBase_parentConstraint1 LipCornerBase_scaleConstraint1 LipTopSidePullOut_parentConstraint1 LipTopSidePullOut_scaleConstraint1 LipTopSideBase_parentConstraint1 LipTopSideBase_scaleConstraint1 LipTopMiddlePullOut_parentConstraint1 LipTopMiddlePullOut_scaleConstraint1 LipTopMiddleBase_parentConstraint1 LipTopMiddleBase_scaleConstraint1 LipBottomSidePullOut_parentConstraint1 LipBottomSideBase_parentConstraint1 LipBottomSidePullOut_scaleConstraint1 LipBottomSideBase_scaleConstraint1 LipBottomMiddlePullOut_parentConstraint1 LipBottomMiddlePullOut_scaleConstraint1 LipBottomMiddleBase_parentConstraint1 LipBottomMiddleBase_scaleConstraint1 LipTopMiddle_parentConstraint1 LipTopMiddle_scaleConstraint1 LipTopMiddleOrigin_parentConstraint1 LipTopMiddleOrigin_scaleConstraint1 LipBottomSideOutline_parentConstraint1 LipBottomSideOutline_scaleConstraint1 LipBottomSide_parentConstraint1 LipBottomSide_scaleConstraint1 LipBottomSideOrigin_parentConstraint1 LipBottomSideOrigin_scaleConstraint1 LipBottom_parentConstraint1 LipBottom_scaleConstraint1 Mouth_parentConstraint1 Mouth_scaleConstraint1 MouthBase_parentConstraint1 MouthBase_scaleConstraint1 Face_parentConstraint1 Face_scaleConstraint1 Head_parentConstraint1 Head_scaleConstraint1 LipBottomMiddleOutline_parentConstraint1 LipBottomMiddleOutline_scaleConstraint1 LipBottomMiddle_parentConstraint1 LipBottomMiddle_scaleConstraint1 LipBottomMiddleOrigin_parentConstraint1 LipBottomMiddleOrigin_scaleConstraint1 LipTopSide_parentConstraint1 LipTopSide_scaleConstraint1 LipTopSideOrigin_parentConstraint1 LipTopSideOrigin_scaleConstraint1 LipTop_parentConstraint1 LipTop_scaleConstraint1 LipCornerOutline_parentConstraint1 LipCornerOutline_scaleConstraint1 LipCorner_parentConstraint1 LipCorner_scaleConstraint1 LipCornerOrigin_parentConstraint1 LipCornerOrigin_scaleConstraint1 NeckTop_parentConstraint1 NeckTop_scaleConstraint1 Neck_parentConstraint1 Neck_scaleConstraint1 MiddleFinger4_parentConstraint1 MiddleFinger4_scaleConstraint1 MiddleFinger3_parentConstraint1 MiddleFinger3_scaleConstraint1 MiddleFinger2_parentConstraint1 MiddleFinger2_scaleConstraint1 MiddleFinger1_parentConstraint1 MiddleFinger1_scaleConstraint1 ThumbFinger4_parentConstraint1 ThumbFinger4_scaleConstraint1 ThumbFinger3_parentConstraint1 ThumbFinger3_scaleConstraint1 ThumbFinger2_parentConstraint1 ThumbFinger2_scaleConstraint1 ThumbFinger1_parentConstraint1 ThumbFinger1_scaleConstraint1 IndexFinger4_parentConstraint1 IndexFinger4_scaleConstraint1 IndexFinger3_parentConstraint1 IndexFinger3_scaleConstraint1 IndexFinger2_parentConstraint1 IndexFinger2_scaleConstraint1 IndexFinger1_parentConstraint1 IndexFinger1_scaleConstraint1 PinkyFinger4_parentConstraint1 PinkyFinger4_scaleConstraint1 PinkyFinger3_parentConstraint1 PinkyFinger3_scaleConstraint1 PinkyFinger2_parentConstraint1 PinkyFinger2_scaleConstraint1 PinkyFinger1_parentConstraint1 PinkyFinger1_scaleConstraint1 RingFinger4_parentConstraint1 RingFinger4_scaleConstraint1 RingFinger3_parentConstraint1 RingFinger3_scaleConstraint1 RingFinger2_parentConstraint1 RingFinger2_scaleConstraint1 RingFinger1_parentConstraint1 RingFinger1_scaleConstraint1 Cup_parentConstraint1 Cup_scaleConstraint1 Wrist_parentConstraint1 Wrist_scaleConstraint1 Elbow_parentConstraint1 Elbow_scaleConstraint1 Shoulder_parentConstraint1 Shoulder_scaleConstraint1 ArmPin_parentConstraint1 ArmPin_scaleConstraint1 Scapula_parentConstraint1 Scapula_scaleConstraint1 Chest_parentConstraint1 Chest_scaleConstraint1 Spine1_parentConstraint1 Spine1_scaleConstraint1 LegPin_parentConstraint1 LegPin_scaleConstraint1 Heel_parentConstraint1 Heel_scaleConstraint1 FootSideInner_parentConstraint1 FootSideInner_scaleConstraint1 FootSideOuter_parentConstraint1 FootSideOuter_scaleConstraint1 ToesEnd_parentConstraint1 ToesEnd_scaleConstraint1 Toes_parentConstraint1 Toes_scaleConstraint1 Ankle_parentConstraint1 Ankle_scaleConstraint1 Knee_parentConstraint1 Knee_scaleConstraint1 Hip_parentConstraint1 Hip_scaleConstraint1 Root_parentConstraint1 Root_scaleConstraint1 AttributeHolder_scaleConstraint1 Wrist_ArmLength_parentConstraint1 Shoulder_ArmLength_parentConstraint1 LegStart_parentConstraint1 LegStart_scaleConstraint1;\ndoDelete;\nselect -r FittingTools ;\ndoDelete;\n\n// Check if createKrogerShelf shelf is present  and deletes it//\n\nif (`objExists createKrogerShelf`) {\n    // Delete createKrogerShelf//\n    select -r createKrogerShelf;\n    doDelete;\n    \n}\n\n\nsetAttr \"CopySkinWeights.visibility\" 0;\nsetAttr \"Root.visibility\" 1;\nsetAttr \"Root.overrideEnabled\" 0;\nsetAttr \"Geo_grp.visibility\" 1;\nsetAttr \"Geo_grp.overrideEnabled\" 1;\nsetAttr \"Geo_grp.overrideDisplayType\" 2;\nsetAttr \"Geo_grp.overrideShading\" 0;\nsetAttr \"Old_GRP.visibility\" 0;\n\nselect -cl  ;\n\nprint(\"Done Deleting the Fitting Group. Now Add joints as necessary and then Click on Build Advanced Skeleton\");" 
        -sourceType "mel" 
        -commandRepeatable 1
        -flat 1
    ;
    shelfButton
        -enableCommandRepeat 1
        -flexibleWidthType 2
        -flexibleWidthValue 100
        -enable 1
        -width 100
        -height 34
        -manage 1
        -visible 1
        -preventOverride 0
        -annotation "Creates Blendshapes, Skinclusters and WireDeformers" 
        -enableBackground 0
        -backgroundColor 0 0 0 
        -highlightColor 0.321569 0.521569 0.65098 
        -align "center" 
        -label "// Create old blink blendshapes //\n\nselect -r r_bigSquint r_btmL..." 
        -labelOffset 0
        -rotation 0
        -flipX 0
        -flipY 0
        -useAlpha 1
        -font "plainLabelFont" 
        -imageOverlayLabel "Connect Deformers" 
        -overlayLabelColor 0.8 0.8 0.8 
        -overlayLabelBackColor 0 0 0 1 
        -image "R:/SANDBOX/carlosS/yellow_100.png" 
        -image1 "R:/SANDBOX/carlosS/yellow_100.png" 
        -style "iconOnly" 
        -marginWidth 1
        -marginHeight 1
        -command "// Check if Build Advanced Skeleton has been executed by checking if the node \"MotionSystem\" exists //\n\nif (`objExists MotionSystem`) {\n    // Continue with the rest of your script\n    print(\"Node named 'MotionSystem' exists. Continuing with the script.\\n\");\n    \n    // Add your additional script logic here\n    \n} else {\n    // Print an error message and stop execution\n    error(\"Error: You forgot to run Build AdvancedSkeleton. Stopping script execution.\\n\");\n}\n\n\n// Create old blink blendshapes //\n\nselect -r r_bigSquint r_btmLidSquint r_sideLidSquint l_bigSquint l_btmLidSquint l_sideLidSquint ;\nselect -add old_head_BLS ;\nblendShape -o local -name BLS_Squints;\n\n// Connect old blink blendshapes //\n\nconnectAttr -f multiplyDivideSquintRight.outputX BLS_Squints.r_bigSquint;\nconnectAttr -f multiplyDivideSquintRight.outputY BLS_Squints.r_btmLidSquint;\nconnectAttr -f multiplyDivideSquintRight.outputZ BLS_Squints.r_sideLidSquint;\nconnectAttr -f multiplyDivideSquintLeft.outputX BLS_Squints.l_bigSquint;\nconnectAttr -f multiplyDivideSquintLeft.outputY BLS_Squints.l_btmLidSquint;\nconnectAttr -f multiplyDivideSquintLeft.outputZ BLS_Squints.l_sideLidSquint;\n\n// Create Blendshapes for new Head and Arms//\n\nselect -r oldEars oldMouth oldNeck oldNose oldEyes closeMouth BlinkR BlinkL newMouth flatMouth flatEyes ;\nselect -add head_BLS ;\nblendShape -o local -name BLS;\nblendShape -edit -w 0 1 BLS;\nconnectAttr -f AttributeHolder.oldEars BLS.oldEars;\nconnectAttr -f AttributeHolder.oldEyes BLS.oldEyes;\nconnectAttr -f AttributeHolder.oldMouth BLS.oldMouth;\nconnectAttr -f AttributeHolder.oldNeck BLS.oldNeck;\nconnectAttr -f AttributeHolder.oldNose BLS.oldNose;\nconnectAttr -f AttributeHolder.flatEyes BLS.flatEyes;\nconnectAttr -f AttributeHolder.flatMouth BLS.flatMouth;\nconnectAttr -f AttributeHolder.newMouth BLS.newMouth;\nconnectAttr -f multiplyDivide4.outputX BLS.BlinkR;\nconnectAttr -f multiplyDivide4.outputY BLS.BlinkL;\nconnectAttr -f multiplyDivide4.outputZ BLS.closeMouth;\n\nselect -r old_head_BLS ;\nselect -add old_head_geo ;\nblendShape -o local -name BLS_OldHead;\nblendShape -edit -w 0 1 BLS_OldHead;\n\nselect -r head_BLS thickNeck;\nselect -add head_geo ;\nblendShape -o local -name BLS_Head;\nblendShape -edit -w 0 1 BLS_Head;\n\nselect -r Skinny Divet_R Divet_L ;\nselect -add Arms_geo ;\nblendShape -o local -name BLS_Arms;\n\n\n// Create Blendshape Selection Sets //\n\nselect -r BLS_OldHead BLS BLS_Head BLS_Arms;\nsets -name Blendshapes;\n\n\n// create CurveWarp Deformers for Mouth and Eye Outlines//\n\nselect -r mouth_outline_geo ;\ndeformer -type curveWarp -n \"curveWarp1\" mouth_outline_geoShape ;\nconnectAttr -f mouth_OutlineCrvShape.worldSpace[0] curveWarp1.inputCurve;\nsetAttr \"curveWarp1.lengthScale\" 2;\nconnectAttr -f curveWarp1_maxScale.output curveWarp1.maxScale;\n\nselect -r r_eye_outline_geo ;\ndeformer -type curveWarp -n \"curveWarp2\" r_eye_outline_geoShape ;\nconnectAttr -f r_eye_OutlineCrvShape.worldSpace[0] curveWarp2.inputCurve;\nsetAttr \"curveWarp2.lengthScale\" 2;\nconnectAttr -f curveWarp2_maxScale.output curveWarp2.maxScale;\n\nselect -r l_eye_outline_geo ;\ndeformer -type curveWarp -n \"curveWarp3\" l_eye_outline_geoShape ;\nconnectAttr -f l_eye_OutlineCrvShape.worldSpace[0] curveWarp3.inputCurve;\nsetAttr \"curveWarp3.lengthScale\" 2;\nconnectAttr -f curveWarp3_maxScale.output curveWarp3.maxScale;\n\n// Create SkinClusters for CopySkinWeights Group//\n\nselect -r ShoulderPart1_L ShoulderPart1_L ShoulderPart2_L Shoulder_L ElbowPart2_L ArmPin_L Scapula_L RingFinger3_L RingFinger2_L PinkyFinger1_L RingFinger1_L Wrist_L Cup_L Elbow_L ElbowPart1_L ThumbFinger1_L IndexFinger3_L IndexFinger2_L IndexFinger1_L PinkyFinger3_L PinkyFinger2_L MiddleFinger3_L MiddleFinger2_L ThumbFinger3_L MiddleFinger1_L ThumbFinger2_L Elbow_R ElbowPart2_R ArmPin_R ShoulderPart2_R Wrist_R Scapula_R ElbowPart1_R Shoulder_R ShoulderPart1_R MiddleFinger1_R MiddleFinger3_R MiddleFinger2_R ThumbFinger2_R IndexFinger3_R ThumbFinger1_R ThumbFinger3_R IndexFinger2_R RingFinger1_R RingFinger3_R IndexFinger1_R PinkyFinger1_R PinkyFinger3_R PinkyFinger2_R RingFinger2_R Cup_R Chest_M;\nselect -add ArmsWeights ;\nskinCluster -tsb -mi 3 -name SkinArmsWeights;\nselect -r Face_M EarBase_R EarTip_R NeckTop_M Neck_M Chest_M EarTip_L EarBase_L NoseSide_L NoseBottom_M Nose_M NoseTop_M NoseSide_R CheekRaiserPullOut_R SmilePullOut_R CheekPullOut_R CheekBonePullOut_R CheekRaiserPullOut_R SmilePullOut_L CheekPullOut_L CheekBonePullOut_L CheekRaiserPullOut_L;\nselect -add HeadWeights;\nskinCluster -tsb -mi 3 -name SkinHeadWeights;\nselect -r LegPin_R Hip_R HipPart1_R HipPart2_R Knee_R Ankle_R Toes_R ToesEnd_R LegPin_L Hip_L HipPart1_L HipPart2_L Knee_L Ankle_L Toes_L ToesEnd_L KneePart1_R KneePart2_R KneePart1_L KneePart2_L;\nselect -add LegWeights ;\nskinCluster -tsb -mi 3 -name SkinLegsWeights;\nselect -r Chest_M Spine1Part2_M Spine1Part1_M Spine1_M RootPart2_M RootPart1_M Root_M Neck_M ;\nselect -add TorsoWeights ;\nskinCluster -tsb -mi 3 -name SkinTorsoWeights;\nselect -r ShoulderPart1_L ShoulderPart1_L ShoulderPart2_L Shoulder_L ElbowPart2_L ArmPin_L Scapula_L RingFinger3_L RingFinger2_L PinkyFinger1_L RingFinger1_L Wrist_L Cup_L Elbow_L ElbowPart1_L ThumbFinger1_L IndexFinger3_L IndexFinger2_L IndexFinger1_L PinkyFinger3_L PinkyFinger2_L MiddleFinger3_L MiddleFinger2_L ThumbFinger3_L MiddleFinger1_L ThumbFinger2_L Elbow_R ElbowPart2_R ArmPin_R ShoulderPart2_R Wrist_R Scapula_R ElbowPart1_R Shoulder_R ShoulderPart1_R MiddleFinger1_R MiddleFinger3_R MiddleFinger2_R ThumbFinger2_R IndexFinger3_R ThumbFinger1_R ThumbFinger3_R IndexFinger2_R RingFinger1_R RingFinger3_R IndexFinger1_R PinkyFinger1_R PinkyFinger3_R PinkyFinger2_R RingFinger2_R Cup_R ;\nselect -add Chest_M Spine1Part2_M Spine1Part1_M Spine1_M RootPart2_M RootPart1_M Root_M Neck_M ;\n\n\n// Create SkinClusters for Geo_grp //\n\nselect -r Face_M EarBase_R EarTip_R NeckTop_M Neck_M Chest_M EarTip_L EarBase_L NoseSide_L NoseBottom_M Nose_M NoseTop_M NoseSide_R CheekRaiserPullOut_R SmilePullOut_R CheekPullOut_R CheekBonePullOut_R CheekRaiserPullOut_R SmilePullOut_L CheekPullOut_L CheekBonePullOut_L CheekRaiserPullOut_L;\nselect -add old_head_geo;\nskinCluster -tsb -mi 3 -name SkinOldHead;\nselect -r Face_M EarBase_R EarTip_R NeckTop_M Neck_M Chest_M EarTip_L EarBase_L NoseSide_L NoseBottom_M Nose_M NoseTop_M NoseSide_R CheekRaiserPullOut_R SmilePullOut_R CheekPullOut_R CheekBonePullOut_R CheekRaiserPullOut_R SmilePullOut_L CheekPullOut_L CheekBonePullOut_L CheekRaiserPullOut_L;\nselect -add old_neck_geo;\nskinCluster -tsb -mi 3 -name SkinOldNeck;\nselect -r Face_M EarBase_R EarTip_R NeckTop_M Neck_M Chest_M EarTip_L EarBase_L NoseSide_L NoseBottom_M Nose_M NoseTop_M NoseSide_R CheekRaiserPullOut_R SmilePullOut_R CheekPullOut_R CheekBonePullOut_R CheekRaiserPullOut_R SmilePullOut_L CheekPullOut_L CheekBonePullOut_L CheekRaiserPullOut_L;\nselect -add  old_nose_geo;\nskinCluster -tsb -mi 3 -name SkinOldNose;\nselect -r Face_M EarBase_R EarTip_R NeckTop_M Neck_M Chest_M EarTip_L EarBase_L NoseSide_L NoseBottom_M Nose_M NoseTop_M NoseSide_R CheekRaiserPullOut_R SmilePullOut_R CheekPullOut_R CheekBonePullOut_R CheekRaiserPullOut_R SmilePullOut_L CheekPullOut_L CheekBonePullOut_L CheekRaiserPullOut_L;\nselect -add old_ears_geo;\nskinCluster -tsb -mi 3 -name SkinOldEars;\nselect -r Face_M EarBase_R EarTip_R NeckTop_M Neck_M Chest_M EarTip_L EarBase_L NoseSide_L NoseBottom_M Nose_M NoseTop_M NoseSide_R CheekRaiserPullOut_R SmilePullOut_R CheekPullOut_R CheekBonePullOut_R CheekRaiserPullOut_R SmilePullOut_L CheekPullOut_L CheekBonePullOut_L CheekRaiserPullOut_L ;\nselect -add head_geo;\nskinCluster -tsb -mi 3 -name SkinHead;\nselect -r Eye_R ;\nselect -add old_r_eye_geo ;\nskinCluster -tsb -mi 1 -name SkinOldREye;\nselect -r Eye_R ;\nselect -add r_eye_geo ;\nskinCluster -tsb -mi 1 -name SkinREye;\nselect -r Eye_L ;\nselect -add old_l_eye_geo ;\nskinCluster -tsb -mi 1 -name SkinOldLEye;\nselect -r Eye_L ;\nselect -add l_eye_geo ;\nskinCluster -tsb -mi 1 -name SkinLEye;\nselect -r TeethLower_M ;\nselect -add teethBtm_geo ;\nskinCluster -tsb -mi 1 -name SkinTeethLower;\nselect -r Tongue_M ;\nselect -add tongue_geo ;\nskinCluster -tsb -mi 1 -name SkinTongue;\nselect -r TeethUpper_M ;\nselect -add teethTop_geo ;\nskinCluster -tsb -mi 1 -name SkinTeethTop;\nselect -r Face_M ;\nselect -add eyeWhite_geo ;\nskinCluster -tsb -mi 1 -name SkinEyeWhite;\nselect -r Face_M ;\nselect -add mouthColor_geo ;\nskinCluster -tsb -mi 1 -name SkinMouthColor;\nselect -r ChewPullOut_R ;\nselect -add R_ChewCheek_geo ;\nskinCluster -tsb -mi 1 -name SkinRChewCheek;\nselect -r ChewPullOut_L ;\nselect -add L_ChewCheek_geo ;\nskinCluster -tsb -mi 1 -name SkinLChewCheek;\nselect -r ShoulderPart1_L ShoulderPart1_L ShoulderPart2_L Shoulder_L ElbowPart2_L ArmPin_L Scapula_L RingFinger3_L RingFinger2_L PinkyFinger1_L RingFinger1_L Wrist_L Cup_L Elbow_L ElbowPart1_L ThumbFinger1_L IndexFinger3_L IndexFinger2_L IndexFinger1_L PinkyFinger3_L PinkyFinger2_L MiddleFinger3_L MiddleFinger2_L ThumbFinger3_L MiddleFinger1_L ThumbFinger2_L Elbow_R ElbowPart2_R ArmPin_R ShoulderPart2_R Wrist_R Scapula_R ElbowPart1_R Shoulder_R ShoulderPart1_R MiddleFinger1_R MiddleFinger3_R MiddleFinger2_R ThumbFinger2_R IndexFinger3_R ThumbFinger1_R ThumbFinger3_R IndexFinger2_R RingFinger1_R RingFinger3_R IndexFinger1_R PinkyFinger1_R PinkyFinger3_R PinkyFinger2_R RingFinger2_R Cup_R Chest_M;\nselect -add Arms_geo ;\nskinCluster -tsb -mi 3 -name SkinArms;\n\n// Create Skincluster Selection Sets //\n\nselect -r SkinArmsWeights SkinHeadWeights SkinLegsWeights SkinTorsoWeights SkinOldHead SkinOldNeck SkinOldNose SkinOldEars SkinHead SkinArms SkinLegsWeights SkinOldREye;\nselect -add  SkinREye SkinOldLEye SkinLEye SkinTeethLower SkinTongue SkinTeethTop SkinEyeWhite SkinMouthColor SkinRChewCheek SkinLChewCheek ;\nsets -name SkinClusters ;\n\n// Make face outlines and other details visible //\n\nsetAttr \"mouth_outline_geo.visibility\" 1;\nsetAttr \"r_eye_outline_geo.visibility\" 1;\nsetAttr \"l_eye_outline_geo.visibility\" 1;\nsetAttr \"R_ChewCheek_geo.visibility\" 1;\nsetAttr \"L_ChewCheek_geo.visibility\" 1;\n\n// Import XML weights to CopySkinWeights group //\n\ndeformerWeights -import -sh \"ArmsWeightsShape\" -path \"R:/SANDBOX/carlosS/Kroger/RIG/WeightsE\" -deformer \"SkinArmsWeights\" \"ArmsWeights.xml\" ;\ndeformerWeights -import -sh \"HeadWeightsShape\" -path \"R:/SANDBOX/carlosS/Kroger/RIG/WeightsE\" -deformer \"SkinHeadWeights\" \"HeadWeights.xml\" ;\ndeformerWeights -import -sh \"LegWeightsShape\" -path \"R:/SANDBOX/carlosS/Kroger/RIG/WeightsE\" -deformer \"SkinLegsWeights\" \"LegWeights.xml\" ;\ndeformerWeights -import -sh \"TorsoWeightsShape\" -path \"R:/SANDBOX/carlosS/Kroger/RIG/WeightsE\" -deformer \"SkinTorsoWeights\" \"TorsoWeights.xml\" ;\ndeformerWeights -import -sh \"Arms_geoShape\" -path \"R:/SANDBOX/carlosS/Kroger/RIG/WeightsE\" -deformer \"BLS_Arms\" \"ArmsBlendshapes.xml\" ;\n\n// Copy weights from CopySkinWeights group  to Geo_grp//\n\nselect -r HeadWeights ;\nselect -add old_head_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -r HeadWeights ;\nselect -add old_neck_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -r HeadWeights ;\nselect -add old_nose_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -r HeadWeights ;\nselect -add old_ears_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -r HeadWeights ;\nselect -add head_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -r ArmsWeights ;\nselect -add Arms_geo ;\ncopySkinWeights  -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint;\nselect -cl  ;\n\n// Create Wire Deformers //\n\nselect -r old_head_geo ;\nselect -add head_geo ;\nselect -r mouth_back_crv mouth_crv ;\nwire  -name wireMouth -gw false -en 1.000000 -ce 0.000000 -li 0.000000 -w mouth_back_crv -w mouth_crv old_head_geo head_geo;\nwire -edit -dds 0 1 -dds 1 9 wireMouth;\nsetAttr \"wireMouth.rotation\" .0;\n\nselect -r old_head_geo ;\nselect -add head_geo ;\nselect -r r_eye_back_crv ;\nselect -add r_eye_crv ;\nwire -name wireREye -gw false -en 1.000000 -ce 0.000000 -li 0.000000 -w r_eye_back_crv -w r_eye_crv old_head_geo head_geo;\nwire -edit -dds 0 1 -dds 1 4 wireREye;\nsetAttr \"wireREye.rotation\" .0;\n\nselect -r old_head_geo ;\nselect -add head_geo ;\nselect -r l_eye_back_crv ;\nselect -add l_eye_crv ;\nwire -name wireLEye -gw false -en 1.000000 -ce 0.000000 -li 0.000000 -w l_eye_back_crv -w l_eye_crv old_head_geo head_geo;\nwire -edit -dds 0 1 -dds 1 4 wireLEye;\nsetAttr \"wireLEye.rotation\" .0;\n\n// Skin Wire Deformers to joints //\n\nselect -r LipCornerPullOut_R LipTopSidePullOut_R LipTopMiddlePullOut_M LipBottomSidePullOut_R LipBottomMiddlePullOut_M ;\nselect -add LipCornerPullOut_L LipTopSidePullOut_L LipBottomSidePullOut_L ;\nselect -add mouth_back_crv ;\nskinCluster -tsb -mi 1 -name SkinMouthBackWire;\n\nselect -r LipCornerPullOut_R LipTopSidePullOut_R LipTopMiddlePullOut_M LipBottomSidePullOut_R LipBottomMiddlePullOut_M ;\nselect -add LipCornerPullOut_L LipTopSidePullOut_L LipBottomSidePullOut_L ;\nselect -add mouth_crv ;\nskinCluster -tsb -mi 1-name SkinMouthWire;\n\nselect -r LidBottomInPullout_R LidBottomMiddlePullout_R LidBottomOutPullout_R LidOutPullout_R LidTopOutPullout_R ;\nselect -add LidTopMiddlePullout_R LidTopInPullout_R LidInPullout_R ;\nselect -add r_eye_back_crv ;\nskinCluster -tsb -mi 1 -name SkinREyeBackWire;\n\nselect -r LidBottomInPullout_R LidBottomMiddlePullout_R LidBottomOutPullout_R LidOutPullout_R ;\nselect -add LidTopOutPullout_R LidTopMiddlePullout_R LidTopInPullout_R LidInPullout_R ;\nselect -add r_eye_crv ;\nskinCluster -tsb -mi 1 -name SkinREyeWire;\n\nselect -r LidInPullout_L LidTopInPullout_L LidTopMiddlePullout_L LidTopOutPullout_L LidOutPullout_L ;\nselect -add LidBottomOutPullout_L LidBottomMiddlePullout_L LidBottomInPullout_L ;\nselect -add l_eye_back_crv ;\nskinCluster -tsb -mi 1 -name SkinLEyeBackWire;\n\nselect -r LidInPullout_L LidTopInPullout_L LidTopMiddlePullout_L LidTopOutPullout_L LidOutPullout_L ;\nselect -add LidBottomOutPullout_L LidBottomMiddlePullout_L LidBottomInPullout_L ;\nselect -add l_eye_crv ;\nskinCluster -tsb -mi 1 -name SkinLEyeWire;\n\n// Skin BaseWire Deformers to Face joint. This allows the wire deformers to follow rig //\n\nselect -r mouth_back_crvBaseWire ;\nselect -add Face_M ;\nskinCluster -tsb -mi 1 -name SkinMouthBackCaseWire;\nselect -r mouth_crvBaseWire ;\nselect -add Face_M ;\nskinCluster -tsb -mi 1 -name SkinMouthBaseWire;\nselect -r r_eye_back_crvBaseWire ;\nselect -add Face_M ;\nskinCluster -tsb -mi 1 -name SkinREyeBackBaseWire;\nselect -r r_eye_crvBaseWire ;\nselect -add Face_M ;\nskinCluster -tsb -mi 1 -name SkinREyeBaseWire;\nselect -r l_eye_back_crvBaseWire ;\nselect -add Face_M ;\nskinCluster -tsb -mi 1 -name SkinLEyeBackBaseWire;\nselect -r l_eye_crvBaseWire ;\nselect -add Face_M ;\nskinCluster -tsb -mi 1 -name SkinLEyeBaseWire;\n\n// Skin Lid and Lip Outline curves to joints //\n\nselect -r LidInOutline_R ;\nselect -add LidTopInOutline_R ;\nselect -add LidTopMiddleOutline_R ;\nselect -add LidTopOutOutline_R ;\nselect -add LidOutOutline_R ;\nselect -add r_eye_OutlineCrv ;\nskinCluster -tsb -mi 1 -name SkinREyeOutline;\n\nselect -r LidInOutline_L ;\nselect -add LidTopInOutline_L ;\nselect -add LidTopMiddleOutline_L ;\nselect -add LidTopOutOutline_L ;\nselect -add LidOutOutline_L ;\nselect -add l_eye_OutlineCrv ; \nskinCluster -tsb -mi 1 -name SkinLEyeOutline;\n\nselect -r LipBottomSideOutline_L ;\nselect -add LipBottomSideOutline_R ;\nselect -add LipBottomMiddleOutline_M ;\nselect -add LipCornerOutline_L ;\nselect -add LipCornerOutlin