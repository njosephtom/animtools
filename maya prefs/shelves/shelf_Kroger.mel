        -commandRepeatable 1
        -flat 1
        -mi "Bind Geo to ARM Joints" ( "// Create a new select set\nsets -name \"ArmsSkins\" ;\nstring $selectSetName = \"ArmsSkins\";\nstring $ArmJoints[] = {\"ShoulderPart1_L\", \"ShoulderPart1_L\", \"ShoulderPart2_L\", \"Shoulder_L\", \"ElbowPart2_L\", \"ArmPin_L\", \"Scapula_L\", \"RingFinger3_L\", \"RingFinger2_L\", \"PinkyFinger1_L\", \"RingFinger1_L\", \"Wrist_L\", \"Cup_L\", \"Elbow_L\", \"ElbowPart1_L\", \"ThumbFinger1_L\", \"IndexFinger3_L\", \"IndexFinger2_L\", \"IndexFinger1_L\", \"PinkyFinger3_L\", \"PinkyFinger2_L\", \"MiddleFinger3_L\", \"MiddleFinger2_L\", \"ThumbFinger3_L\", \"MiddleFinger1_L\", \"ThumbFinger2_L\", \"Elbow_R\", \"ElbowPart2_R\", \"ArmPin_R\", \"ShoulderPart2_R\", \"Wrist_R\", \"Scapula_R\", \"ElbowPart1_R\", \"Shoulder_R\", \"ShoulderPart1_R\", \"MiddleFinger1_R\", \"MiddleFinger3_R\", \"MiddleFinger2_R\", \"ThumbFinger2_R\", \"IndexFinger3_R\", \"ThumbFinger1_R\", \"ThumbFinger3_R\", \"IndexFinger2_R\", \"RingFinger1_R\", \"RingFinger3_R\", \"IndexFinger1_R\", \"PinkyFinger1_R\", \"PinkyFinger3_R\", \"PinkyFinger2_R\", \"RingFinger2_R\", \"Cup_R\", \"Chest_M\"};\n       \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Bind the target meshes to joints\nfor ($targetMesh in $targetMeshes) {\n        \n    // Bind the selected geometry to the specified joints using the skinCluster command\n    select -r  $targetMesh ; \n    select -add  $ArmJoints ;  \n    skinCluster -tsb -mi 3;\n    \n}\n\n// Create a new select set\nstring $sourceMesh = \"ArmsWeights\";\n\n// Get the skin cluster from the mesh\nstring $skinClusters[] = `skinCluster -q -inf $sourceMesh`;\n        \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Copy weights from the source mesh to the target meshes\nfor ($targetMesh in $targetMeshes) {\n        \n        \n    // Copy the weights from the source mesh to the target mesh\n    select -r ArmsWeights;\n    select -add  $targetMesh ;   \n    copySkinWeights -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint ;\n    \n}\n\nselect -r -ne \"ArmsSkins*\" ;\ndoDelete;" )
        -mi "----------------------------------------------" ( "print(\"User defined menuItem\");" )
        -mi "Bind Geo to TORSO Joints" ( "// Create a new select set\nsets -name \"TorsoSkins\" ;\nstring $selectSetName = \"TorsoSkins\";\nstring $TorsoJoints[] = {\"Chest_M\", \"Spine1Part2_M\", \"Spine1Part1_M\", \"Spine1_M\", \"RootPart2_M\", \"RootPart1_M\", \"Root_M\", \"Neck_M\"};\n       \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Bind the target meshes to joints\nfor ($targetMesh in $targetMeshes) {\n        \n    // Bind the selected geometry to the specified joints using the skinCluster command\n    select -r  $targetMesh ; \n    select -add  $TorsoJoints ;  \n    skinCluster -tsb -mi 3;\n    \n}\n\n// Create a new select set\nstring $sourceMesh = \"TorsoWeights\";\n\n// Get the skin cluster from the mesh\nstring $skinClusters[] = `skinCluster -q -inf $sourceMesh`;\n        \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Copy weights from the source mesh to the target meshes\nfor ($targetMesh in $targetMeshes) {\n        \n        \n    // Copy the weights from the source mesh to the target mesh\n    select -r TorsoWeights;\n    select -add  $targetMesh ;   \n    copySkinWeights -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint ;\n    \n}\n\nselect -r -ne \"TorsoSkins*\" ;\ndoDelete;" )
        -mi "----------------------------------------------" ( "print(\"User defined menuItem\");" )
        -mi "Bind Geo to LEG Joints" ( "// Create a new select set\nsets -name \"LegSkins\" ;\nstring $selectSetName = \"LegSkins\";\nstring $LegJoints[] = {\"LegPin_R\", \"Hip_R\", \"HipPart1_R\", \"HipPart2_R\", \"Knee_R\", \"KneePart1_R\", \"KneePart2_R\", \"Ankle_R\", \"Toes_R\", \"LegPin_L\", \"Hip_L\", \"HipPart1_L\", \"HipPart2_L\", \"Knee_L\", \"KneePart1_L\", \"KneePart2_L\", \"Ankle_L\", \"Toes_L\"};\n      \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Bind the target meshes to joints\nfor ($targetMesh in $targetMeshes) {\n        \n    // Bind the selected geometry to the specified joints using the skinCluster command\n    select -r  $targetMesh ; \n    select -add  $LegJoints ;  \n    skinCluster -tsb -mi 3;\n    \n}\n\n// Create a new select set\nstring $sourceMesh = \"LegWeights\";\n\n// Get the skin cluster from the mesh\nstring $skinClusters[] = `skinCluster -q -inf $sourceMesh`;\n        \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Copy weights from the source mesh to the target meshes\nfor ($targetMesh in $targetMeshes) {\n        \n        \n    // Copy the weights from the source mesh to the target mesh\n    select -r LegWeights;\n    select -add  $targetMesh ;   \n    copySkinWeights -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint ;\n    \n}\n\nselect -r -ne \"LegSkins*\" ;\ndoDelete;" )
        -mi "----------------------------------------------" ( "print(\"User defined menuItem\");" )
        -mi "Bind Geo to EAR Joints" ( "// Create a new select set\nsets -name \"EarSkins\" ;\nstring $selectSetName = \"EarSkins\";\nstring $EarJoints[] = {\"EarBase_L\", \"EarTip_L\", \"EarTip_R\", \"EarBase_R\", \"Head_M\"};\n      \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Bind the target meshes to joints\nfor ($targetMesh in $targetMeshes) {\n        \n    // Bind the selected geometry to the specified joints using the skinCluster command\n    select -r  $targetMesh ; \n    select -add  $EarJoints ;  \n    skinCluster -tsb -mi 3;\n    \n}\n\n// Create a new select set\nstring $sourceMesh = \"HeadWeights\";\n\n// Get the skin cluster from the mesh\nstring $skinClusters[] = `skinCluster -q -inf $sourceMesh`;\n        \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Copy weights from the source mesh to the target meshes\nfor ($targetMesh in $targetMeshes) {\n        \n        \n    // Copy the weights from the source mesh to the target mesh\n    select -r HeadWeights;\n    select -add  $targetMesh ;   \n    copySkinWeights -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint ;\n    \n}\n\nselect -r -ne \"EarSkins*\" ;\ndoDelete;" )
        -mi "----------------------------------------------" ( "print(\"User defined menuItem\");" )
        -mi "Bind Geo to HEAD Joint" ( "// Create a new select set\nsets -name \"HeadSkins\" ;\nstring $selectSetName = \"HeadSkins\";\nstring $HeadJoints[] = {\"Head_M\"};\n       \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Bind the target meshes to joints\nfor ($targetMesh in $targetMeshes) {\n        \n    // Bind the selected geometry to the specified joints using the skinCluster command\n    select -r  $targetMesh ; \n    select -add  $HeadJoints ;  \n    skinCluster -tsb -mi 3;\n    \n}\n\n// Create a new select set\nstring $sourceMesh = \"HeadWeights\";\n\n// Get the skin cluster from the mesh\nstring $skinClusters[] = `skinCluster -q -inf $sourceMesh`;\n        \n// Get the list of objects in the select set\nstring $targetMeshes[] = `sets -q $selectSetName`;\n\n// Copy weights from the source mesh to the target meshes\nfor ($targetMesh in $targetMeshes) {\n        \n        \n    // Copy the weights from the source mesh to the target mesh\n    select -r HeadWeights;\n    select -add  $targetMesh ;   \n    copySkinWeights -noMirror -surfaceAssociation closestPoint -influenceAssociation closestJoint ;\n    \n}\n\nselect -r -ne \"HeadSkins*\" ;\ndoDelete;" )
        -mi "----------------------------------------------" ( "print(\"User defined menuItem\");" )
        -mi "EXTRA: Select Arm AND Torso Joints" ( "select -r ShoulderPart1_L ShoulderPart1_L ShoulderPart2_L Shoulder_L ElbowPart2_L ArmPin_L Scapula_L RingFinger3_L RingFinger2_L PinkyFinger1_L RingFinger1_L Wrist_L Cup_L Elbow_L ElbowPart1_L ThumbFinger1_L IndexFinger3_L IndexFinger2_L IndexFinger1_L PinkyFinger3_L PinkyFinger2_L MiddleFinger3_L MiddleFinger2_L ThumbFinger3_L MiddleFinger1_L ThumbFinger2_L Elbow_R ElbowPart2_R ArmPin_R ShoulderPart2_R Wrist_R Scapula_R ElbowPart1_R Shoulder_R ShoulderPart1_R MiddleFinger1_R MiddleFinger3_R MiddleFinger2_R ThumbFinger2_R IndexFinger3_R ThumbFinger1_R ThumbFinger3_R IndexFinger2_R RingFinger1_R RingFinger3_R IndexFinger1_R PinkyFinger1_R PinkyFinger3_R PinkyFinger2_R RingFinger2_R Cup_R ;\nselect -add Chest_M Spine1Part2_M Spine1Part1_M Spine1_M RootPart2_M RootPart1_M Root_M Neck_M ;" )
        -mi "EXTRA: Select AllHead Joints" ( "" )
